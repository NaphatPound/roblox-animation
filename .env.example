# Copy to `.env.local` (gitignored) and fill in values.

# --- Backend selection ----------------------------------------------------
# auto (default): try cloud first if OLLAMA_API_KEY is set, then local.
# cloud: require OLLAMA_API_KEY, fail hard if it's unavailable.
# local: ignore OLLAMA_API_KEY entirely, use OLLAMA_URL.
# OLLAMA_BACKEND=auto

# --- Ollama Cloud ---------------------------------------------------------
# https://docs.ollama.com/api/authentication
# Set this to enable the cloud path. Leave empty to run local-only.
OLLAMA_API_KEY=

# Cloud-tagged models. When OLLAMA_API_KEY is set and these are unset, the
# app falls back to sensible cloud defaults (gpt-oss:120b-cloud for text,
# gemma4:31b-cloud for vision).
OLLAMA_TEXT_MODEL=gpt-oss:120b-cloud
OLLAMA_VISION_MODEL=gemma4:31b-cloud

# Override cloud base URL if you run a compatible proxy.
# OLLAMA_CLOUD_URL=https://ollama.com

# --- Local Ollama daemon --------------------------------------------------
# Used when no cloud key is set OR when auto-mode falls back after a cloud
# failure. When in local mode the app defaults to llama3.2 / gemma3.
# OLLAMA_URL=http://localhost:11434
