# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored so keys never reach git.

# --- Ollama Cloud (preferred) ---
# Set this to route /api/ai-text and /api/ai-vision through Ollama Cloud
# (https://docs.ollama.com/api/authentication). Leave empty to use a local
# Ollama daemon instead.
OLLAMA_API_KEY=

# Cloud text-completion model. Example cloud-tagged models:
#   glm-5.1:cloud, gpt-oss:120b-cloud, deepseek-v3.1:671b-cloud
OLLAMA_TEXT_MODEL=glm-5.1:cloud

# Vision model used by /api/ai-vision.
OLLAMA_VISION_MODEL=glm-5.1:cloud

# --- Local Ollama (fallback / dev) ---
# URL of a running `ollama serve` instance. Only used when OLLAMA_API_KEY
# is empty.
# OLLAMA_URL=http://localhost:11434

# Override cloud base URL if you self-host a compatible proxy.
# OLLAMA_CLOUD_URL=https://ollama.com
